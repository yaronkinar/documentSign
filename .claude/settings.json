{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "node scripts/generate-site-versions.mjs",
            "timeout": 60,
            "statusMessage": "Updating site version changelog…"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/generate-site-versions.mjs",
            "timeout": 60,
            "statusMessage": "Updating site version changelog…"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/run-e2e-stop.js",
            "timeout": 900,
            "statusMessage": "Running Playwright E2E…"
          }
        ]
      }
    ]
  }
}
