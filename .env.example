# ─── Clerk ──────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
# Enable email + password in Clerk Dashboard:
# User & Authentication → Email → Sign-up with email + Sign-in with email
# User & Authentication → Password → Sign-up with password

# ─── Database ───────────────────────────────────────────────────
# Defaults to the Docker-managed MongoDB service
MONGODB_URI=mongodb://mongodb:27017/docflow

# ─── Redis ──────────────────────────────────────────────────────
# Defaults to the Docker-managed Redis service
REDIS_URL=redis://redis:6379

# ─── Storage ──────────────────────────────────────────────────────
# supabase = production (requires healthy Supabase DB + bucket)
# local    = filesystem via API (good for Docker dev when Supabase is down)
STORAGE_DRIVER=local
# Optional — relative to apps/api. Omit to use repo-root .local-storage.
# LOCAL_STORAGE_PATH=../../.local-storage
API_PUBLIC_URL=http://localhost:3001

# ─── Supabase Storage (when STORAGE_DRIVER=supabase) ─────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me
SUPABASE_STORAGE_BUCKET=docflow-files

# ─── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_replace_me
EMAIL_FROM=noreply@example.com

# ─── Invite tokens ──────────────────────────────────────────────
INVITE_TOKEN_SECRET=a-long-random-secret-change-me

# ─── URLs ───────────────────────────────────────────────────────
# Must be accessible from the user's browser, not Docker-internal
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
WEB_URL=http://localhost:3000

# ─── AI summarization (optional) ────────────────────────────────
# OpenAI (default)
# OPENAI_API_KEY=sk_replace_me
# OPENAI_MODEL=gpt-4o-mini

# Local LLM via Ollama — set base URL, any non-empty key, and the model name
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2

# Local LLM via LM Studio
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=lm-studio
# OPENAI_MODEL=llama-3.2-3b-instruct

# ─── Dev auth bypass (optional) ─────────────────────────────────
# BYPASS_AUTH=true
# BYPASS_TOKEN=dev-bypass-token
# BYPASS_AUTH_EMAIL=you@example.com
# NEXT_PUBLIC_BYPASS_AUTH=true
# NEXT_PUBLIC_BYPASS_TOKEN=dev-bypass-token
