# Clerk
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_WEBHOOK_SECRET=whsec_replace_me

# MongoDB
MONGODB_URI=mongodb://localhost:27017/docflow

# Storage (local filesystem — see apps/api/src/storage/local-storage.backend.ts)
STORAGE_DRIVER=local

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Email (Resend)
RESEND_API_KEY=re_replace_me
EMAIL_FROM=noreply@example.com
# Local dev with onboarding@resend.dev: sandbox only delivers to your Resend account email.
# With BYPASS_AUTH=true, mail to +alias signers is redirected to BYPASS_AUTH_EMAIL automatically.
# Or set explicitly: DEV_EMAIL_REDIRECT=you@gmail.com

# Invite tokens
INVITE_TOKEN_SECRET=a-long-random-secret-string-change-me

# URLs
WEB_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Railway (set on the api service):
# WEB_URL=https://${{web.RAILWAY_PUBLIC_DOMAIN}}
# Optional comma-separated extra CORS origins (e.g. Railway preview URLs)
# CORS_ORIGINS=https://web-staging.up.railway.app

# Server
PORT=3001

# AI provider: openai (default) or anthropic
# AI_PROVIDER=openai

# OpenAI (default provider)
OPENAI_API_KEY=sk_replace_me
# Optional — defaults to gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Claude (set AI_PROVIDER=anthropic). System prompts are prompt-cached (~90% cheaper on repeat calls).
# ANTHROPIC_API_KEY=sk-ant-replace_me
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_VISION_MODEL=claude-opus-4-8
# AI_CACHE_DEBUG=true
